@inherits LayoutComponentBase
@page "/"
<div class="page">

	<div class="main">
		<NavBar @bind-siteIndex="siteIndex" />

		<div class="content px-4">
			@switch (siteIndex)
			{
				case 1:
					<AboutMe />
					break;
				case 2:
					<Accomplishments />
					break;
				case 3:
					<Experience />
					break;
				case 4:
					<Contact/>
					break;
			}

		</div>

	</div>
</div>